#!/bin/sh

if [ -x /opt/homebrew/bin/fish ]; then
    exec /opt/homebrew/bin/fish "$@"
elif [ -x /usr/local/bin/fish ]; then
    exec /usr/local/bin/fish "$@"
elif command -v zsh >/dev/null 2>&1; then
    exec zsh "$@"
elif command -v bash >/dev/null 2>&1; then
    exec bash "$@"
else
    exec sh "$@"
fi
